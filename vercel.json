{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/api/sui-rpc",
      "destination": "/api/sui-rpc"
    },
    {
      "source": "/api/solana-rpc",
      "destination": "/api/solana-rpc"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}

